#SBATCH --cpus-per-task=16
#SBATCH -o example_outputs/CV-KRR-L-SPAHM_e-splitting-TM-GSspinPlus.out
#SBATCH -e example_outputs/CV-KRR-L-SPAHM_e-splitting-TM-GSspinPlus.err

conda activate benchmark_tmc

python -u cross_validation.py --x TM-GSspinPlus/0-repr/SPAHM_e-TM-GSspinPlus.npy --y TM-GSspinPlus/1-prop/splitting-TM-GSspinPlus.txt --indices TM-GSspinPlus/2-cv10-splits --akernel myLfast --ada --save --name example_outputs/CV-KRR-L-SPAHM_e-splitting-TM-GSspinPlus

exit 0
