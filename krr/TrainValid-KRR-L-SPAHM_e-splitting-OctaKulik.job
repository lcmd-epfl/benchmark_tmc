#SBATCH -e example_outputs/TrainValid-KRR-L-SPAHM_e-splitting-OctaKulik.err

conda activate benchmark_tmc

python -u final_error.py --x OctaKulik/splitting/0-repr/SPAHM_e_LS-OctaKulik.npy --y OctaKulik/splitting/1-prop/splitting-OctaKulik.txt --train_idx OctaKulik/splitting/3-train-valid-meyer/0-train_indices.txt --test_idx OctaKulik/splitting/3-train-valid-meyer/0-test_indices.txt --akernel myLfast --ada --save --name example_outputs/TrainValid-KRR-L-SPAHM_e-splitting-OctaKulik

