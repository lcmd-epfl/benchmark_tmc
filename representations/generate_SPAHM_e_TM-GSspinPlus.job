#!/bin/bash -l
#SBATCH --job-name=generate_SPAHM_e_TM-GSspinPlus
#SBATCH --mem=32GB
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=16
#SBATCH -o example_outputs/generate_SPAHM_e_TM-GSspinPlus.out
#SBATCH -e example_outputs/generate_SPAHM_e_TM-GSspinPlus.err
#SBATCH --partition=standard
#SBATCH --time=1-00:00:00

conda activate benchmark_tmc

cd TM-GSspinPlus
python -u "generate_rep_spahm_qstack.py" --rep "SPAHM_e" --xyz "/home/ycho/benchmark_tmc/data/TM-GSspinPlus/0-xyz" 
