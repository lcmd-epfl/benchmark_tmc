python -u "generate_rep_spahm_qstack.py" --rep "SPAHM_e" --xyz "/home/ycho/benchmark_tmc/data/TM-GSspinPlus/0-xyz" --subset "subset_refcodes/TM-GSspinPlus_sub_0.txt"
